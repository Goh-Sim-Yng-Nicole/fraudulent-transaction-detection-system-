# Server Configuration
NODE_ENV=production
PORT=3008
SERVICE_NAME=analytics-service
SERVICE_VERSION=1.0.0
LOG_LEVEL=info

# Database Configuration (Read-only access to decision DB)
DB_HOST=decision-db
DB_PORT=5432
DB_NAME=decision_db
DB_USER=decision_admin
DB_PASSWORD=decision_password
DB_MAX_CONNECTIONS=10
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# Appeal Database Configuration (read-only access)
APPEAL_DB_ENABLED=true
APPEAL_DB_HOST=appeal-db
APPEAL_DB_PORT=5432
APPEAL_DB_NAME=appeal_db
APPEAL_DB_USER=appeal_admin
APPEAL_DB_PASSWORD=appeal_password
APPEAL_DB_MAX_CONNECTIONS=10
APPEAL_DB_IDLE_TIMEOUT=30000
APPEAL_DB_CONNECTION_TIMEOUT=2000

# Redis Configuration (for time-series metrics)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=5
REDIS_PASSWORD=

# Kafka Configuration (optional, for real-time streaming)
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=analytics-service
KAFKA_GROUP_ID=analytics-group
KAFKA_ENABLE_CONSUMER=false
KAFKA_TOPICS=transaction.finalised,transaction.flagged

# Analytics Configuration
METRICS_RETENTION_HOURS=168
METRICS_AGGREGATION_INTERVAL_SECONDS=60
ENABLE_REAL_TIME_UPDATES=true

# WebSocket Configuration
WS_ENABLED=true
WS_HEARTBEAT_INTERVAL=30000

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9098
