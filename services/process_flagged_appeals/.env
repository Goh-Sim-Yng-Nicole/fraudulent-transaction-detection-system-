# Server
NODE_ENV=development
PORT=3010
SERVICE_NAME=human-verification-service
SERVICE_VERSION=1.0.0
LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=human_review_db
DB_USER=review_admin
DB_PASSWORD=review_password
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=human-verification-service
KAFKA_GROUP_ID=human-verification-group
KAFKA_INPUT_TOPIC_FLAGGED=transaction.flagged
KAFKA_OUTPUT_TOPIC_REVIEWED=transaction.reviewed
KAFKA_DLQ_TOPIC=transaction.review.dlq
KAFKA_CONSUMER_SESSION_TIMEOUT=30000
KAFKA_CONSUMER_HEARTBEAT_INTERVAL=3000

# Appeal Service Integration (analyst workflow)
APPEAL_SERVICE_URL=http://appeal-service:3011
APPEAL_SERVICE_TIMEOUT_MS=4000
