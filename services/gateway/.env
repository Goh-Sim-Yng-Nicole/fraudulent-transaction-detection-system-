# Server Configuration
NODE_ENV=development
PORT=3000
SERVICE_NAME=api-gateway
LOG_LEVEL=info

# JWT Configuration
JWT_SECRET=dev-secret-123
JWT_EXPIRES_IN=24h
JWT_ISSUER=fraud-detection-platform

# Redis Configuration
REDIS_HOST=localhost  # use localhost for dev, and change to redis when running on docker
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CONNECT_TIMEOUT=10000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false
TXN_RATE_LIMIT_WINDOW_MS=60000
TXN_RATE_LIMIT_MAX_PER_CUSTOMER=30
TXN_RATE_LIMIT_KEY_PREFIX=txn:customer:

# Service Routes
TRANSACTION_SERVICE_URL=http://transaction-service:3001
ML_SCORING_SERVICE_URL=http://ml-scoring-service:3004
AUDIT_SERVICE_URL=http://audit-service:3007
ANALYTICS_SERVICE_URL=http://analytics-service:3008
HUMAN_VERIFICATION_SERVICE_URL=http://human-verification-service:3010
APPEAL_SERVICE_URL=http://appeal-service:3011

# Circuit Breaker Configuration
CIRCUIT_BREAKER_TIMEOUT=3000
CIRCUIT_BREAKER_ERROR_THRESHOLD=50
CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# CORS Configuration
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# Proxy Configuration
PROXY_TIMEOUT=30000
PROXY_RETRY_ATTEMPTS=3
PROXY_RETRY_DELAY=1000

# Metrics
METRICS_ENABLED=true
METRICS_PORT=9090

# Health Check
HEALTH_CHECK_INTERVAL=30000
