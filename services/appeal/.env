NODE_ENV=development
PORT=3011
SERVICE_NAME=appeal-service
SERVICE_VERSION=1.0.0
LOG_LEVEL=info

# PostgreSQL
DB_HOST=appeal-db
DB_PORT=5432
DB_NAME=appeal_db
DB_USER=appeal_admin
DB_PASSWORD=appeal_password
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# Dependencies
TRANSACTION_SERVICE_URL=http://transaction-service:3001

# Kafka
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=appeal-service
KAFKA_OUTPUT_TOPIC_APPEAL_CREATED=appeal.created
KAFKA_OUTPUT_TOPIC_APPEAL_RESOLVED=appeal.resolved
KAFKA_DLQ_TOPIC=appeal.dlq
