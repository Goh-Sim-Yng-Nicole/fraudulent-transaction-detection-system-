# Server Config
NODE_ENV=production
PORT=3007
SERVICE_NAME=audit-service
SERVICE_VERSION=1.0.0
LOG_LEVEL=info

# Database Config
DB_HOST=audit-db
DB_PORT=5432
DB_NAME=audit_db
DB_USER=audit_admin
DB_PASSWORD=audit_password
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# Kafka Config
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=audit-service
KAFKA_GROUP_ID=audit-group
KAFKA_CONSUMER_SESSION_TIMEOUT=30000
KAFKA_CONSUMER_HEARTBEAT_INTERVAL=3000

# Kafka Topics (Subscribe to ALL events)
KAFKA_TOPICS=transaction.created,transaction.scored,transaction.finalised,transaction.flagged,transaction.decision.dlq,notification.dlq

# Audit Config
# Enable event hash verification (tamper detection)
ENABLE_HASH_VERIFICATION=true
# Retention period (days) - 0 means infinite
AUDIT_RETENTION_DAYS=2555
# Enable event chain validation
ENABLE_CHAIN_VALIDATION=true

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9097