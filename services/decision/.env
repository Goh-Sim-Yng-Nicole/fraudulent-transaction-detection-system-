# Server Configuration
NODE_ENV=production
PORT=3005
SERVICE_NAME=decision-engine-service
SERVICE_VERSION=1.0.0
LOG_LEVEL=info

# Database Configuration
DB_HOST=decision-db
DB_PORT=5432
DB_NAME=decision_db
DB_USER=decision_admin
DB_PASSWORD=decision_password
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# Kafka Configuration
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=decision-engine-service
KAFKA_GROUP_ID=decision-engine-group
KAFKA_CONSUMER_SESSION_TIMEOUT=30000
KAFKA_CONSUMER_HEARTBEAT_INTERVAL=3000

# Kafka Topics─
KAFKA_INPUT_TOPIC=transaction.scored
KAFKA_OUTPUT_TOPIC_APPROVED=transaction.finalised
KAFKA_OUTPUT_TOPIC_FLAGGED=transaction.flagged
KAFKA_DLQ_TOPIC=transaction.decision.dlq

# Decision Thresholds
# Risk score thresholds (0-100)
THRESHOLD_APPROVE_MAX=49
THRESHOLD_FLAG_MIN=50
THRESHOLD_FLAG_MAX=79
THRESHOLD_DECLINE_MIN=80

# Override thresholds for specific conditions
THRESHOLD_RULES_FLAGGED_AUTO_DECLINE=true
THRESHOLD_HIGH_CONFIDENCE_APPROVE=0.95
THRESHOLD_LOW_CONFIDENCE_FLAG=0.60

# Amount-based overrides
THRESHOLD_HIGH_VALUE_AMOUNT=10000
THRESHOLD_HIGH_VALUE_AUTO_FLAG=true

# Business Rules
AUTO_APPROVE_WHITELIST_CUSTOMERS=
AUTO_DECLINE_BLACKLIST_CUSTOMERS=
REQUIRE_MANUAL_REVIEW_COUNTRIES=NG,RU,CN,PK

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9095