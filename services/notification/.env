# Server Configuration
NODE_ENV=production
PORT=3006
SERVICE_NAME=notification-service
SERVICE_VERSION=1.0.0
LOG_LEVEL=info

# Kafka Configuration
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=notification-service
KAFKA_GROUP_ID=notification-group
KAFKA_CONSUMER_SESSION_TIMEOUT=30000
KAFKA_CONSUMER_HEARTBEAT_INTERVAL=3000

# Kafka Topics
KAFKA_INPUT_TOPIC_FINALISED=transaction.finalised
KAFKA_INPUT_TOPIC_FLAGGED=transaction.flagged
KAFKA_DLQ_TOPIC=notification.dlq

# Retry Configuration
RETRY_MAX_ATTEMPTS=3
RETRY_INITIAL_DELAY_MS=1000
RETRY_BACKOFF_MULTIPLIER=2
RETRY_MAX_DELAY_MS=10000

# Email Configuration (Mock/SMTP)
EMAIL_ENABLED=true
EMAIL_PROVIDER=mock
# For real SMTP (Gmail, SendGrid, etc):
# EMAIL_PROVIDER=smtp
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_SECURE=false
# EMAIL_SMTP_USER=your-email@gmail.com
# EMAIL_SMTP_PASSWORD=your-app-password
EMAIL_FROM_ADDRESS=noreply@frauddetection.com
EMAIL_FROM_NAME=Fraud Detection System

# SMS Configuration (Mock/Twilio)
SMS_ENABLED=true
SMS_PROVIDER=mock
# For real Twilio:
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=your-account-sid
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# Notification Rules
# Which decisions trigger notifications
NOTIFY_ON_APPROVED=false
NOTIFY_ON_DECLINED=true
NOTIFY_ON_FLAGGED=true

# Notification channels per decision type
DECLINED_NOTIFY_CUSTOMER_EMAIL=true
DECLINED_NOTIFY_CUSTOMER_SMS=true
DECLINED_NOTIFY_FRAUD_TEAM_EMAIL=true

FLAGGED_NOTIFY_FRAUD_TEAM_EMAIL=true
FLAGGED_NOTIFY_FRAUD_TEAM_SMS=false

# Rate Limiting
RATE_LIMIT_EMAIL_PER_MINUTE=60
RATE_LIMIT_SMS_PER_MINUTE=30

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9096
