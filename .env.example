# Kafka
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# Postgres (each microservice has its own DB)
POSTGRES_TRANSACTION_DB=ftds_transaction
POSTGRES_TRANSACTION_USER=postgres
POSTGRES_TRANSACTION_PASSWORD=postgres

POSTGRES_APPEAL_DB=ftds_appeal
POSTGRES_APPEAL_USER=postgres
POSTGRES_APPEAL_PASSWORD=postgres

POSTGRES_FRAUD_REVIEW_DB=ftds_fraud_review
POSTGRES_FRAUD_REVIEW_USER=postgres
POSTGRES_FRAUD_REVIEW_PASSWORD=postgres

POSTGRES_DECISION_DB=ftds_decision
POSTGRES_DECISION_USER=postgres
POSTGRES_DECISION_PASSWORD=postgres

POSTGRES_AUDIT_DB=ftds_audit
POSTGRES_AUDIT_USER=postgres
POSTGRES_AUDIT_PASSWORD=postgres

POSTGRES_CUSTOMER_DB=ftds_customer
POSTGRES_CUSTOMER_USER=postgres
# CHANGE THIS in production — never use the default password in production!
POSTGRES_CUSTOMER_PASSWORD=postgres

# JWT — MUST be a long random string in production.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-use-a-long-random-secret-in-production
JWT_EXPIRE_MINUTES=60

# For running a service outside Docker, set its own DATABASE_URL, e.g.:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ftds_customer

# Service URLs (Docker Compose service names)
FRAUD_SCORE_URL=http://fraud-score:8001/score
REDIS_DISABLED=true

# Fraud detection heuristics
HIGH_RISK_COUNTRIES=NG,RU,CN,PK
HIGH_AMOUNT_THRESHOLD=5000
SUSPICIOUS_AMOUNT_THRESHOLD=10000
VELOCITY_MAX_COUNT_PER_HOUR=8
VELOCITY_MAX_AMOUNT_PER_HOUR=15000
COMBINATION_RULES_WEIGHT=0.45
COMBINATION_ML_WEIGHT=0.55
ML_FLAG_THRESHOLD=70

# Analyst / manager credentials for copied Node services
ANALYST_USERNAME=analyst
ANALYST_PASSWORD=analyst123
ANALYST_JWT_SECRET=analyst-dev-secret-change-in-prod
MANAGER_USERNAME=manager
MANAGER_PASSWORD=manager123
MANAGER_JWT_SECRET=manager-dev-secret-change-in-prod

# Decision thresholds (0-100)
APPROVE_MAX_SCORE=40
FLAG_MAX_SCORE=70

# Topic names
TOPIC_TRANSACTION_CREATED=transaction.created
TOPIC_TRANSACTION_SCORED=transaction.scored
TOPIC_TRANSACTION_FLAGGED=transaction.flagged
TOPIC_TRANSACTION_FINALISED=transaction.finalised
TOPIC_TRANSACTION_REVIEWED=transaction.reviewed
TOPIC_APPEAL_CREATED=appeal.created
TOPIC_APPEAL_RESOLVED=appeal.resolved
