# Kafka
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092

# Runtime security posture
# Keep this false for local Docker. Set it to true in staging/production so services reject demo secrets.
SECURITY_ENFORCE_STRICT_CONFIG=false

# Postgres (each microservice has its own DB)
POSTGRES_TRANSACTION_DB=ftds_transaction
POSTGRES_TRANSACTION_USER=postgres
POSTGRES_TRANSACTION_PASSWORD=postgres

POSTGRES_APPEAL_DB=ftds_appeal
POSTGRES_APPEAL_USER=postgres
POSTGRES_APPEAL_PASSWORD=postgres

POSTGRES_FRAUD_REVIEW_DB=ftds_fraud_review
POSTGRES_FRAUD_REVIEW_USER=postgres
POSTGRES_FRAUD_REVIEW_PASSWORD=postgres

POSTGRES_AUDIT_DB=ftds_audit
POSTGRES_AUDIT_USER=postgres
POSTGRES_AUDIT_PASSWORD=postgres

POSTGRES_DECISION_DB=ftds_decision
POSTGRES_DECISION_USER=postgres
POSTGRES_DECISION_PASSWORD=postgres

POSTGRES_CUSTOMER_DB=ftds_customer
POSTGRES_CUSTOMER_USER=postgres
# CHANGE THIS in production — never use the default password in production!
POSTGRES_CUSTOMER_PASSWORD=postgres

# JWT — local Docker must stay aligned with Kong's declarative JWT credential in kong/kong.yml.
# Replace this with your own strong secret outside local/demo environments.
JWT_SECRET=ftds-dev-secret-change-in-production-32chars
JWT_EXPIRE_MINUTES=60
JWT_EXPIRES_IN=24h
JWT_ISSUER=fraud-detection-platform
CUSTOMER_JWT_ISSUER=ftds-customer-service

# Gateway/browser security defaults for local Docker
CORS_ORIGIN=http://localhost,http://127.0.0.1,http://localhost:8088,http://127.0.0.1:8088
CORS_CREDENTIALS=false

# For running a service outside Docker, set its own DATABASE_URL, e.g.:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ftds_customer

# Service URLs (Docker Compose service names)
FRAUD_SCORE_URL=http://fraud-score:8001/score
REDIS_DISABLED=true
# Use in-repo decision engine by default (no OutSystems required).
DECISION_INTEGRATION_MODE=outsystems_kafka
DECISION_ENGINE_SERVICE_URL=http://decision:3005
OUTSYSTEMS_DECISION_URL=
ENABLE_LOCAL_DECISION_FALLBACK=false
OUTSYSTEMS_AUTH_TYPE=none
OUTSYSTEMS_BEARER_TOKEN=
OUTSYSTEMS_AUTH_HEADER_NAME=X-API-Key
OUTSYSTEMS_AUTH_HEADER_VALUE=

# Fraud detection heuristics
HIGH_RISK_COUNTRIES=NG,RU,CN,PK
HIGH_AMOUNT_THRESHOLD=5000
SUSPICIOUS_AMOUNT_THRESHOLD=10000
VELOCITY_MAX_COUNT_PER_HOUR=10
VELOCITY_MAX_AMOUNT_PER_HOUR=10000
VELOCITY_MAX_COUNT_PER_DAY=50
VELOCITY_MAX_DISTINCT_RECIPIENTS_PER_HOUR=4
VELOCITY_MAX_DISTINCT_MERCHANTS_PER_HOUR=5
FIRST_TIME_RECIPIENT_REVIEW_AMOUNT=1500
HIGH_RISK_MERCHANT_REVIEW_AMOUNT=400
PREPAID_HIGH_AMOUNT_THRESHOLD=2500
BIN_BLACKLIST=
HIGH_RISK_MERCHANT_IDS=
HIGH_RISK_MERCHANT_PREFIXES=CRYPTO_,GIFT_,CASHOUT_,FTDS_FLAGGED
SCORING_VELOCITY_COUNT_HOUR=15
SCORING_VELOCITY_AMOUNT_HOUR=20
SCORING_VELOCITY_COUNT_DAY=10
SCORING_HIGH_RISK_COUNTRY=25
SCORING_SUSPICIOUS_AMOUNT=30
SCORING_HIGH_AMOUNT=10
SCORING_UNUSUAL_TIME=5
SCORING_ROUND_AMOUNT=5
SCORING_BIN_BLACKLIST=40
COMBINATION_RULES_WEIGHT=0.4
COMBINATION_ML_WEIGHT=0.6
ML_FLAG_THRESHOLD=70

# Analyst / manager credentials for copied Node services
ANALYST_USERNAME=analyst
ANALYST_PASSWORD=analyst123
ANALYST_JWT_SECRET=analyst-dev-secret-change-in-prod
ANALYST_API_TOKEN=
MANAGER_USERNAME=manager
MANAGER_PASSWORD=manager123
MANAGER_JWT_SECRET=manager-dev-secret-change-in-prod
MANAGER_API_TOKEN=
OPS_READONLY_USERNAME=opsviewer
OPS_READONLY_PASSWORD=opsviewer123
OPS_ADMIN_USERNAME=opsadmin
OPS_ADMIN_PASSWORD=opsadmin123
STAFF_SESSION_COOKIE_NAME=ftds_staff_token
STAFF_SESSION_MAX_AGE_MS=43200000
COOKIE_SECURE_ONLY=false

# Decision thresholds used by the local detect_fraud fallback when OutSystems is not configured
THRESHOLD_APPROVE_MAX=49
THRESHOLD_FLAG_MIN=50
THRESHOLD_FLAG_MAX=75
THRESHOLD_DECLINE_MIN=76

# Topic names
TOPIC_TRANSACTION_CREATED=transaction.created
TOPIC_TRANSACTION_SCORED=transaction.scored
TOPIC_TRANSACTION_FLAGGED=transaction.flagged
TOPIC_TRANSACTION_FINALISED=transaction.finalised
TOPIC_TRANSACTION_REVIEWED=transaction.reviewed
TOPIC_APPEAL_CREATED=appeal.created
TOPIC_APPEAL_RESOLVED=appeal.resolved

# observability
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123
GRAFANA_ALLOW_SIGN_UP=false
GRAFANA_ANONYMOUS_ENABLED=true
GRAFANA_ANONYMOUS_ORG_ROLE=Viewer
OTEL_ENABLED=true
OTEL_SERVICE_NAMESPACE=ftds-platform
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_PROPAGATORS=tracecontext,baggage

# Notification service defaults for CI/local demo.
# Keep these on Mailpit here so GitHub Actions and clean local stacks do not depend on external providers.
# For localhost and deployment, override EMAIL_* and SMS_*/TWILIO_* in your real .env.
EMAIL_ENABLED=true
EMAIL_PROVIDER=smtp
EMAIL_SMTP_HOST=mailpit
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_SECURE=false
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_ADDRESS=alerts@ftds.local
EMAIL_FROM_NAME=FTDS Notifications
SMS_ENABLED=false
CUSTOMER_PORTAL_URL=http://localhost:8088/banking
SMS_PROVIDER=twilio
TWILIO_PHONE_NUMBER=
NOTIFY_ON_APPROVED=true
NOTIFY_ON_DECLINED=true
NOTIFY_ON_FLAGGED=true
APPROVED_NOTIFY_CUSTOMER_EMAIL=true
APPROVED_NOTIFY_CUSTOMER_SMS=false
DECLINED_NOTIFY_CUSTOMER_EMAIL=true
DECLINED_NOTIFY_CUSTOMER_SMS=false
DECLINED_NOTIFY_FRAUD_TEAM_EMAIL=true
FLAGGED_NOTIFY_CUSTOMER_EMAIL=true
FLAGGED_NOTIFY_CUSTOMER_SMS=false
FLAGGED_NOTIFY_FRAUD_TEAM_EMAIL=true
FLAGGED_NOTIFY_FRAUD_TEAM_SMS=false
NOTIFICATION_CUSTOMER_FALLBACK_EMAIL=demo-customer@frauddetection.com
NOTIFICATION_CUSTOMER_FALLBACK_PHONE=+15550000000
NOTIFICATION_FRAUD_TEAM_EMAIL=fraud.notifications@frauddetection.com
NOTIFICATION_FRAUD_TEAM_PHONE=+15550000001

# Customer OTP delivery stays on Mailpit for the local/demo journey.
# This repo does not send OTP through SMS; Mailpit is only used for the email OTP demo flow.
CUSTOMER_SMTP_HOST=mailpit
CUSTOMER_SMTP_PORT=1025
CUSTOMER_SMTP_USER=
CUSTOMER_SMTP_PASSWORD=
CUSTOMER_SMTP_FROM=banking@ftds.local
CUSTOMER_SMTP_STARTTLS=false

# Customer OAuth (Google)
# Enable by setting all 3 values below.
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=

# Public app base URL used for OAuth callback redirects (defaults to request host if unset).
PUBLIC_BASE_URL=http://localhost:8088

# Deployment profile (set these on the VM when serving the browser over HTTPS)
# DEPLOYMENT_HOST=ftds.eastasia.cloudapp.azure.com
# PUBLIC_BASE_URL=https://ftds.eastasia.cloudapp.azure.com
# CUSTOMER_PORTAL_URL=https://ftds.eastasia.cloudapp.azure.com/banking
# CORS_ORIGIN=https://ftds.eastasia.cloudapp.azure.com
# COOKIE_SECURE_ONLY=true
# OAUTH_GOOGLE_REDIRECT_URI=https://ftds.eastasia.cloudapp.azure.com/api/auth/oauth/callback

