{
  "name": "ftds-platform-tests",
  "private": true,
  "type": "module",
  "scripts": {
    "unit:py": "python -m unittest discover -s unit_py -p \"*_test.py\"",
    "unit:js": "node ./unit/run-tests.mjs",
    "unit": "npm run unit:py && npm run unit:js",
    "smoke": "node ./smoke-health.mjs",
    "contracts": "node ./service-contracts.mjs",
    "e2e": "node ./e2e-platform.mjs",
    "verify": "npm run unit && npm run smoke && npm run contracts && npm run e2e"
  }
}
