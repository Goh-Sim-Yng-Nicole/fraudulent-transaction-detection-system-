{
  "name": "fraudulent-transaction-detection-system",
  "private": true,
  "scripts": {
    "lint:js": "eslint \"services/**/*.js\" \"testing/**/*.mjs\" \"eslint.config.mjs\" --max-warnings=0",
    "lint:py": "node ./testing/run-python.mjs -m ruff check services/customer services/transaction services/detect_fraud ftds testing/unit_py",
    "lint": "npm run lint:js && npm run lint:py",
    "format:check": "prettier --check \"README.md\" \"package.json\" \"testing/package.json\" \"docker-compose.yml\" \"otel-collector-config.yml\" \".github/workflows/*.{yml,yaml}\" \"grafana/provisioning/**/*.yml\" \"kong/**/*.yml\" \"prometheus/**/*.yml\" \"jaeger/**/*.json\" \".prettierrc.json\"",
    "format:write": "prettier --write \"README.md\" \"package.json\" \"testing/package.json\" \"docker-compose.yml\" \"otel-collector-config.yml\" \".github/workflows/*.{yml,yaml}\" \"grafana/provisioning/**/*.yml\" \"kong/**/*.yml\" \"prometheus/**/*.yml\" \"jaeger/**/*.json\" \".prettierrc.json\"",
    "quality": "npm run lint && npm run format:check",
    "test:unit:py": "node ./testing/run-python.mjs -m unittest discover -s testing/unit_py -p \"*_test.py\"",
    "test:unit:js": "node ./testing/unit/run-tests.mjs",
    "test:unit": "npm run test:unit:py && npm run test:unit:js",
    "test:smoke": "node ./testing/smoke-health.mjs",
    "test:contracts": "node ./testing/service-contracts.mjs",
    "test:e2e": "node ./testing/e2e-platform.mjs",
    "test:journey": "node ./testing/full-platform-journey.mjs",
    "test:verify": "npm run test:unit && npm run test:smoke && npm run test:contracts && npm run test:e2e && npm run test:journey"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "eslint": "^9.21.0",
    "globals": "^15.15.0",
    "prettier": "^3.5.3"
  }
}
